# ============================================================
# CentralStore Docker Environment
# ============================================================
# Skopiujte tento soubor jako .env a upravte hesla:
#   cp .env.example .env
# ============================================================

# --- PostgreSQL ---
POSTGRES_USER=centralstore
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=centralstore_master
POSTGRES_PORT=5432

# --- pgAdmin ---
PGADMIN_EMAIL=admin@centralstore.local
PGADMIN_PASSWORD=CHANGE_ME
PGADMIN_PORT=5050

# --- RabbitMQ ---
RABBITMQ_USER=centralstore
RABBITMQ_PASSWORD=CHANGE_ME
RABBITMQ_VHOST=centralstore
RABBITMQ_AMQP_PORT=5672
RABBITMQ_MGMT_PORT=15672
